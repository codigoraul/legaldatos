---
import Layout from '../../layouts/Layout.astro';

const WP_BASE = import.meta.env.PUBLIC_WP_URL ?? 'http://localhost:10189';

type Category = {
	id: number;
	name: string;
	slug: string;
};

let categoryTabs: Array<{ slug: string; name: string; id: number | null }> = [
	{ slug: 'todas', name: 'Todas', id: null },
];

try {
	const catsRes = await fetch(`${WP_BASE}/wp-json/wp/v2/categories?per_page=100`, {
		headers: { Accept: 'application/json' },
	});
	if (catsRes.ok) {
		const categories: Category[] = await catsRes.json();
		const targetCategories = ['Datos personales', 'Derecho Laboral', 'Temas generales', 'Compliance de datos'];
		const filtered = categories.filter((c) =>
			targetCategories.some((t) => c.name.toLowerCase() === t.toLowerCase())
		);
		categoryTabs = [
			{ slug: 'todas', name: 'Todas', id: null },
			...filtered.map((c) => ({ slug: c.slug, name: c.name, id: c.id })),
		];
	}
} catch (_) {
	// tabs show only "Todas" on error
}

const hero = { title: 'Todas las Publicaciones' };
---

<Layout hero={hero}>
	<section class="pub-section">
		<div class="container">
			<nav class="category-tabs">
				{categoryTabs.map((tab) => (
					<a
						href={tab.slug === 'todas' ? '/publicaciones/todas/' : `/publicaciones/todas/?categoria=${tab.slug}`}
						class="tab"
						data-slug={tab.slug}
					>
						{tab.name}
					</a>
				))}
			</nav>

			<div id="section-header" class="section-header" style="display:none">
				<h2 class="section-title" id="section-title"></h2>
				<p class="section-count" id="section-count"></p>
			</div>

			<div id="posts-container">
				<div class="loading-state">
					<p>Cargando publicaciones…</p>
				</div>
			</div>

			<nav id="pagination" class="pagination"></nav>
		</div>
	</section>
</Layout>

<script define:vars={{ WP_BASE, categoryTabs }}>
	const PER_PAGE = 24;

	function getParams() {
		const p = new URLSearchParams(window.location.search);
		return {
			categoria: p.get('categoria') || 'todas',
			page: parseInt(p.get('page') || '1'),
		};
	}

	function formatDate(dateStr) {
		if (!dateStr) return '';
		return new Date(dateStr).toLocaleDateString('es-CL', {
			day: 'numeric',
			month: 'long',
			year: 'numeric',
		});
	}

	function setActiveTabs(categoria) {
		document.querySelectorAll('.tab').forEach((tab) => {
			tab.classList.toggle('active', tab.dataset.slug === categoria);
		});
	}

	function renderPagination(current, total, categoria) {
		const nav = document.getElementById('pagination');
		if (total <= 1) { nav.innerHTML = ''; return; }

		const catParam = categoria !== 'todas' ? `categoria=${categoria}&` : '';
		let html = '';

		if (current > 1) {
			html += `<a href="/publicaciones/todas/?${catParam}page=${current - 1}" class="page-btn">← Anterior</a>`;
		}

		html += '<div class="page-numbers">';
		for (let i = 1; i <= total; i++) {
			const show = i === 1 || i === total || (i >= current - 2 && i <= current + 2);
			const ellipsis = i === current - 3 || i === current + 3;
			if (show) {
				html += `<a href="/publicaciones/todas/?${catParam}page=${i}" class="page-num${i === current ? ' active' : ''}">${i}</a>`;
			} else if (ellipsis) {
				html += `<span class="ellipsis">…</span>`;
			}
		}
		html += '</div>';

		if (current < total) {
			html += `<a href="/publicaciones/todas/?${catParam}page=${current + 1}" class="page-btn">Siguiente →</a>`;
		}

		nav.innerHTML = html;
	}

	function renderGrid(posts, total, categoria, page, categoryName) {
		const container = document.getElementById('posts-container');
		const header = document.getElementById('section-header');
		const titleEl = document.getElementById('section-title');
		const countEl = document.getElementById('section-count');
		const totalPages = Math.ceil(total / PER_PAGE);

		if (categoria !== 'todas' && categoryName) {
			header.style.display = 'block';
			titleEl.textContent = categoryName;
			countEl.textContent = `${total} publicaciones`;
		} else {
			header.style.display = 'none';
		}

		if (posts.length === 0) {
			container.innerHTML = '<p class="empty">No hay publicaciones disponibles.</p>';
			renderPagination(1, 0, categoria);
			return;
		}

		const cards = posts.map((post) => {
			const image = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
			const alt = (post._embedded?.['wp:featuredmedia']?.[0]?.alt_text || post.title?.rendered || '').replace(/"/g, '&quot;');
			const url = `/articulos/${post.slug}/`;
			const dateLabel = formatDate(post.date);
			const terms = post._embedded?.['wp:term']?.[0];
			const cats = terms?.map((t) => t.name).join(', ') || '';

			return `<article class="pub-card">
				<a href="${url}" class="card-link">
					${image ? `<img src="${image}" alt="${alt}" loading="lazy" class="thumb" />` : `<div class="thumb-placeholder"></div>`}
					<div class="card-content">
						${cats ? `<span class="category">${cats}</span>` : ''}
						<h3 class="card-title">${post.title?.rendered || ''}</h3>
						${dateLabel ? `<span class="date">${dateLabel}</span>` : ''}
					</div>
				</a>
			</article>`;
		});

		container.innerHTML = `<div class="grid">${cards.join('')}</div>`;
		renderPagination(page, totalPages, categoria);
	}

	async function loadPosts() {
		const { categoria, page } = getParams();
		setActiveTabs(categoria);

		try {
			const tab = categoryTabs.find((t) => t.slug === categoria);
			const categoryId = tab?.id ?? null;
			const categoryName = tab?.name ?? '';

			const catParam = categoryId ? `&categories=${categoryId}` : '';
			const res = await fetch(
				`${WP_BASE}/wp-json/wp/v2/posts?_embed&per_page=${PER_PAGE}&page=${page}${catParam}`
			);

			if (!res.ok) throw new Error(`HTTP ${res.status}`);

			const total = parseInt(res.headers.get('X-WP-Total') || '0');
			const posts = await res.json();

			renderGrid(posts, total, categoria, page, categoryName);
		} catch (e) {
			document.getElementById('posts-container').innerHTML =
				'<p class="empty">Error al cargar publicaciones. Intenta de nuevo.</p>';
		}
	}

	loadPosts();
</script>

<style is:global>
	.pub-section {
		padding: 80px 0;
		background: #fff;
		min-height: 60vh;
	}

	.category-tabs {
		display: flex;
		justify-content: center;
		gap: 8px;
		margin-bottom: 40px;
		border-bottom: 2px solid #E5E7EB;
		flex-wrap: wrap;
	}

	.tab {
		padding: 14px 28px;
		text-decoration: none;
		color: #6B7280;
		font-weight: 500;
		font-size: 15px;
		white-space: nowrap;
		border-bottom: 3px solid transparent;
		margin-bottom: -2px;
		transition: all 0.25s ease;
		border-radius: 4px 4px 0 0;
	}

	.tab:hover {
		color: #0C1630;
		background: rgba(12, 22, 48, 0.05);
	}

	.tab.active {
		color: #0C1630;
		font-weight: 700;
		border-bottom-color: #0C1630;
		border-bottom-width: 3px;
		background: rgba(12, 22, 48, 0.04);
	}

	@media (max-width: 768px) {
		.category-tabs {
			justify-content: flex-start;
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
		}
		.category-tabs::-webkit-scrollbar { display: none; }
		.tab { padding: 12px 20px; font-size: 14px; }
	}

	.section-header {
		margin: 48px 0 32px;
		text-align: center;
	}

	.section-title {
		font-size: 32px;
		font-weight: 700;
		color: #0C1630;
		margin: 0 0 8px;
	}

	.section-count {
		font-size: 14px;
		color: #6B7280;
		margin: 0;
	}

	.loading-state {
		text-align: center;
		padding: 60px 0;
		color: #6B7280;
	}

	.empty {
		text-align: center;
		color: #6B7280;
		font-size: 16px;
		padding: 60px 0;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 24px;
		margin-bottom: 48px;
	}

	.pub-card {
		background: #fff;
		border-radius: 12px;
		overflow: hidden;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		border: 1px solid rgba(0, 0, 0, 0.08);
	}

	.pub-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
	}

	.card-link {
		display: block;
		text-decoration: none;
		height: 100%;
	}

	.thumb {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		display: block;
	}

	.thumb-placeholder {
		width: 100%;
		aspect-ratio: 16 / 9;
		background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
	}

	.card-content { padding: 16px; }

	.category {
		display: inline-block;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 8px;
		letter-spacing: 0.5px;
	}

	.card-title {
		font-size: 16px;
		font-weight: 600;
		line-height: 1.4;
		margin: 0 0 8px;
		color: var(--primary);
	}

	.card-link:hover .card-title { color: var(--accent); }

	.date {
		display: block;
		font-size: 12px;
		color: var(--muted);
		text-transform: capitalize;
	}

	.pagination {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		margin-top: 48px;
	}

	.page-btn {
		padding: 10px 20px;
		background: var(--primary);
		color: white;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 600;
		font-size: 14px;
		transition: background 0.2s ease;
	}

	.page-btn:hover { background: var(--accent); }

	.page-numbers {
		display: flex;
		gap: 6px;
		align-items: center;
	}

	.page-num {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 8px;
		text-decoration: none;
		color: var(--primary);
		font-weight: 500;
		font-size: 14px;
		transition: all 0.2s ease;
		border: 1px solid rgba(0, 0, 0, 0.1);
	}

	.page-num:hover { background: rgba(0, 0, 0, 0.05); }

	.page-num.active {
		background: var(--primary);
		color: white;
		border-color: var(--primary);
	}

	.ellipsis {
		color: var(--muted);
		padding: 0 4px;
	}

	@media (max-width: 1100px) {
		.grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
	}

	@media (max-width: 768px) {
		.grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
		.pub-section { padding: 48px 0; }
		.pagination { flex-wrap: wrap; gap: 8px; }
		.page-btn { padding: 8px 16px; font-size: 13px; }
		.page-num { width: 36px; height: 36px; font-size: 13px; }
	}

	@media (max-width: 480px) {
		.grid { grid-template-columns: 1fr; }
	}
</style>
