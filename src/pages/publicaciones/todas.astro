---
import Layout from '../../layouts/Layout.astro';

const WP_BASE = import.meta.env.PUBLIC_WP_URL ?? 'http://localhost:10189';
const basePath = '';

type Post = {
	id: number;
	slug: string;
	title: { rendered: string };
	date?: string;
	categories?: number[];
	_embedded?: {
		['wp:featuredmedia']?: Array<{ source_url?: string; alt_text?: string }>;
		['wp:term']?: Array<Array<{ id: number; name: string; slug: string }>>;
	};
};

type Category = {
	id: number;
	name: string;
	slug: string;
};

const currentPage = parseInt(Astro.url.searchParams.get('page') || '1');
const selectedCategory = Astro.url.searchParams.get('categoria') || 'todas';
const postsPerPage = 24;

let allPosts: Post[] = [];
let categories: Category[] = [];
let totalPosts = 0;
let loadError: string | null = null;
let categoryTabs: Array<{ slug: string; name: string }> = [];

try {
	const [catsRes] = await Promise.all([
		fetch(`${WP_BASE}/wp-json/wp/v2/categories?per_page=100`, {
			headers: { Accept: 'application/json' },
		}),
	]);

	if (!catsRes.ok) throw new Error(`WP categories ${catsRes.status}`);
	categories = (await catsRes.json()) as Category[];

	const targetCategories = ['Datos personales', 'Derecho Laboral', 'Temas generales', 'Compliance de datos'];
	const filteredCategories = categories.filter((c) => 
		targetCategories.some((target) => c.name.toLowerCase() === target.toLowerCase())
	);

	categoryTabs = [
		{ slug: 'todas', name: 'Todas' },
		...filteredCategories.map((c) => ({ slug: c.slug, name: c.name }))
	];

	let categoryId: number | undefined;
	if (selectedCategory !== 'todas') {
		const category = categories.find((c) => c.slug === selectedCategory);
		categoryId = category?.id;
	}

	const categoryParam = categoryId ? `&categories=${categoryId}` : '';
	const postsRes = await fetch(
		`${WP_BASE}/wp-json/wp/v2/posts?_embed&per_page=${postsPerPage}&page=${currentPage}${categoryParam}`,
		{
			headers: { Accept: 'application/json' },
		}
	);

	if (!postsRes.ok) throw new Error(`WP posts ${postsRes.status}`);

	totalPosts = parseInt(postsRes.headers.get('X-WP-Total') || '0');
	allPosts = (await postsRes.json()) as Post[];
} catch (e) {
	loadError = e instanceof Error ? e.message : 'Error desconocido';
}

const totalPages = Math.ceil(totalPosts / postsPerPage);

const formatDate = (dateStr?: string) => {
	if (!dateStr) return '';
	const date = new Date(dateStr);
	return date.toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric' });
};

const getCategoryNames = (post: Post) => {
	const terms = post._embedded?.['wp:term']?.[0];
	if (!terms || terms.length === 0) return '';
	return terms.map((t) => t.name).join(', ');
};

const shouldShowPageNumber = (pageNum: number, current: number, total: number) => {
	if (pageNum === 1 || pageNum === total) return true;
	const minPage = current - 2;
	const maxPage = current + 2;
	if (pageNum >= minPage && pageNum < maxPage + 1) return true;
	return false;
};

const shouldShowEllipsis = (pageNum: number, current: number) => {
	return pageNum === current - 3 || pageNum === current + 3;
};

const hero = {
	title: 'Todas las Publicaciones',
};
---

<Layout hero={hero}>
	{loadError ? (
		<section class="section">
			<div class="container">
				<p style="margin: 0; color: rgba(185, 28, 28, 0.9);">No se pudo cargar desde WordPress ({WP_BASE}). Error: {loadError}</p>
			</div>
		</section>
	) : (
		<section class="pub-section">
			<div class="container">
				<nav class="category-tabs">
					{categoryTabs.map((tab) => (
						<a
							href={`/publicaciones/todas/?categoria=${tab.slug}`}
							class={`tab ${selectedCategory === tab.slug ? 'active' : ''}`}
						>
							{tab.name}
						</a>
					))}
				</nav>

				<div class="header-info">
					<p class="total-count">Mostrando {allPosts.length} de {totalPosts} publicaciones</p>
				</div>

				{allPosts.length === 0 ? (
					<p class="empty">No hay publicaciones disponibles.</p>
				) : (
					<div class="grid">
						{allPosts.map((post) => {
							const image = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
							const alt = post._embedded?.['wp:featuredmedia']?.[0]?.alt_text ?? post.title?.rendered;
							const url = `${basePath}/articulos/${post.slug}/`;
							const dateLabel = formatDate(post.date);
							const categoryNames = getCategoryNames(post);
							return (
								<article class="pub-card">
									<a href={url} class="card-link">
										{image ? (
											<img src={image} alt={alt} loading="lazy" class="thumb" />
										) : (
											<div class="thumb-placeholder"></div>
										)}
										<div class="card-content">
											{categoryNames && <span class="category">{categoryNames}</span>}
											<h3 class="card-title" set:html={post.title?.rendered} />
											{dateLabel && <span class="date">{dateLabel}</span>}
										</div>
									</a>
								</article>
							);
						})}
					</div>
				)}

				{totalPages > 1 && (
					<nav class="pagination">
						{currentPage > 1 && (
							<a href={`/publicaciones/todas/?categoria=${selectedCategory}&page=${currentPage - 1}`} class="page-btn prev">
								← Anterior
							</a>
						)}
						
						<div class="page-numbers">
							{Array.from({ length: totalPages }, (_, i) => i + 1).map((pageNum) => {
								if (shouldShowPageNumber(pageNum, currentPage, totalPages)) {
									return (
										<a
											href={`/publicaciones/todas/?categoria=${selectedCategory}&page=${pageNum}`}
											class={`page-num ${pageNum === currentPage ? 'active' : ''}`}
										>
											{pageNum}
										</a>
									);
								} else if (shouldShowEllipsis(pageNum, currentPage)) {
									return <span class="ellipsis">…</span>;
								}
								return null;
							})}
						</div>

						{currentPage < totalPages && (
							<a href={`/publicaciones/todas/?categoria=${selectedCategory}&page=${currentPage + 1}`} class="page-btn next">
								Siguiente →
							</a>
						)}
					</nav>
				)}
			</div>
		</section>
	)}
</Layout>

<style>
	.pub-section {
		padding: 80px 0;
		background: #fff;
		min-height: 60vh;
	}

	.category-tabs {
		display: flex;
		gap: 0;
		margin-bottom: 40px;
		border-bottom: 2px solid rgba(0, 0, 0, 0.1);
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}

	.tab {
		padding: 14px 20px;
		text-decoration: none;
		color: #6B7280;
		font-weight: 500;
		font-size: 14px;
		white-space: nowrap;
		border-bottom: 3px solid transparent;
		margin-bottom: -2px;
		transition: all 0.2s ease;
		position: relative;
	}

	.tab:hover {
		color: var(--primary);
		background: rgba(12, 22, 48, 0.03);
	}

	.tab.active {
		color: var(--primary);
		font-weight: 600;
		border-bottom-color: var(--primary);
		background: rgba(12, 22, 48, 0.02);
	}

	.header-info {
		margin-bottom: 32px;
		text-align: center;
	}

	.total-count {
		color: var(--muted);
		font-size: 14px;
		margin: 0;
	}

	.empty {
		text-align: center;
		color: var(--muted);
		font-size: 16px;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 24px;
		margin-bottom: 48px;
	}

	.pub-card {
		background: #fff;
		border-radius: 12px;
		overflow: hidden;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		border: 1px solid rgba(0, 0, 0, 0.08);
	}

	.pub-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
	}

	.card-link {
		display: block;
		text-decoration: none;
		height: 100%;
	}

	.thumb {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		display: block;
	}

	.thumb-placeholder {
		width: 100%;
		aspect-ratio: 16 / 9;
		background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
	}

	.card-content {
		padding: 16px;
	}

	.category {
		display: inline-block;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 8px;
		letter-spacing: 0.5px;
	}

	.card-title {
		font-size: 16px;
		font-weight: 600;
		line-height: 1.4;
		margin: 0 0 8px;
		color: var(--primary);
	}

	.card-link:hover .card-title {
		color: var(--accent);
	}

	.date {
		display: block;
		font-size: 12px;
		color: var(--muted);
		text-transform: capitalize;
	}

	.pagination {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		margin-top: 48px;
	}

	.page-btn {
		padding: 10px 20px;
		background: var(--primary);
		color: white;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 600;
		font-size: 14px;
		transition: background 0.2s ease;
	}

	.page-btn:hover {
		background: var(--accent);
	}

	.page-numbers {
		display: flex;
		gap: 6px;
		align-items: center;
	}

	.page-num {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 8px;
		text-decoration: none;
		color: var(--primary);
		font-weight: 500;
		font-size: 14px;
		transition: all 0.2s ease;
		border: 1px solid rgba(0, 0, 0, 0.1);
	}

	.page-num:hover {
		background: rgba(0, 0, 0, 0.05);
	}

	.page-num.active {
		background: var(--primary);
		color: white;
		border-color: var(--primary);
	}

	.ellipsis {
		color: var(--muted);
		padding: 0 4px;
	}

	@media (max-width: 1100px) {
		.grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 768px) {
		.grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 16px;
		}

		.pub-section {
			padding: 48px 0;
		}

		.pagination {
			flex-wrap: wrap;
			gap: 8px;
		}

		.page-btn {
			padding: 8px 16px;
			font-size: 13px;
		}

		.page-num {
			width: 36px;
			height: 36px;
			font-size: 13px;
		}
	}

	@media (max-width: 480px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
